{
  "definitions": [
    {
      "title": "Category Carousel",
      "id": "category-carousel",
      "model": "category-carousel",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 1,
          "fields": [
            {
              "name": "categories",
              "selector": "div>div.category-carousel>div.category-item"
            }
          ]
        }
      }
    },
    {
      "title": "Category Item",
      "id": "category-item",
      "model": "category-item",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 1,
          "fields": [
            { "name": "image", "selector": "div>div.category-item>picture>img[src]" },
            { "name": "alt", "selector": "div>div.category-item>picture>img[alt]" },
            { "name": "title", "selector": "div>div.category-item>h3" },
            { "name": "ctaText", "selector": "div>div.category-item>a" },
            { "name": "ctaLink", "selector": "div>div.category-item>a[href]" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "category-carousel",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "categories",
          "label": "Categories",
          "multi": true
        }
      ]
    },
    {
      "id": "category-item",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Category Image",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "alt",
          "label": "Alt Text",
          "value": ""
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Title",
          "value": ""
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ctaText",
          "label": "CTA Text",
          "value": "Shop Now"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ctaLink",
          "label": "CTA Link",
          "value": ""
        }
      ]
    }
  ],
  "filters": []
}